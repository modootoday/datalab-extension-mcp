{
  "name": "@modootoday/datalab-extension-mcp",
  "version": "1.2.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "datalab-extension-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^4.0.18",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "@modootoday/extension-app-mcp-core": "*",
    "@modootoday/extension-app-mcp-installer": "*",
    "@modootoday/extension-app-mcp-server": "*"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modootoday/datalab-extension-mcp.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/modootoday/datalab-extension-mcp#readme",
  "license": "MIT",
  "description": "Local MCP server that exposes the DataLab Tools browser extension's read-only tools to an MCP host. Holds no credentials; every call runs inside your own browser session.",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "chrome-extension",
    "naver"
  ]
}
